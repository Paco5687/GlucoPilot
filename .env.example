# ── Core ──────────────────────────────────────────────────────────────────
# Public HTTPS URL the app is served at (behind your reverse proxy).
APP_PUBLIC_URL=https://glucopilot.example.com

# Admin login. Leave APP_PASSWORD_HASH blank to create the password on first
# visit (recommended). APP_SECRET_KEY signs session cookies — set it to a long
# random string and keep it stable, or sessions reset on restart.
APP_USERNAME=
APP_PASSWORD_HASH=
APP_SECRET_KEY=replace-with-a-long-random-secret

# Timezone for pattern/cycle analysis and imports (IANA name).
APP_TIMEZONE=America/New_York

# Background sync loop on/off (per-source intervals are in server/scheduler.py).
SYNC_ENABLED=true

# Demo mode: no login, auto-seeds synthetic data. NEVER on real data.
# DEMO_MODE=false

# ── Most integration credentials are entered in the in-app Settings page and
#    stored in the database — you do NOT need them here. The env vars below are
#    only bootstrap defaults; the Settings page overrides them. ───────────────

# Dexcom (developer.dexcom.com). PRODUCTION ONLY — no sandbox (a sandbox user
# consumes your limited production user slots). OAuth is user-initiated.
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=
DEXCOM_REDIRECT_URI=https://glucopilot.example.com/dexcom/callback
DEXCOM_ENV=production_us

# Oura (cloud.ouraring.com). Register redirect: {APP_PUBLIC_URL}/oura-callback
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# Fitbit (dev.fitbit.com, "Personal" app). Redirect: {APP_PUBLIC_URL}/fitbit-callback
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# ── AI ────────────────────────────────────────────────────────────────────
# The AI Analyst, pattern/insight narratives, lab extraction, and Visit Report
# use either the Anthropic API or a local OpenAI-compatible server. Choose the
# provider on the Settings page. For a fully-private setup, use a local model
# (a vision-capable one is required for lab-report extraction).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Local model endpoints (optional; see docs/LOCAL_MODELS.md). Defaults assume
# the Unix-socket proxy pattern documented there.
# LOCAL_LLM_URL=unix:///run/glucopilot/llm.sock
# LOCAL_LLM_MODEL=your-vision-model
# QUALITY_LLM_URL=unix:///run/glucopilot/ollama.sock   # bigger model for the report
# QUALITY_LLM_MODEL=gemma3:27b

# ── Reverse proxy (this repo ships Traefik labels; adapt for nginx/caddy) ────
TRAEFIK_HOST=glucopilot.example.com
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
# External Docker network your reverse proxy is on (see docker-compose.yml).
TRAEFIK_NETWORK=web
# Attach an existing/renamed data volume (advanced; default is glucopilot_data).
# DATA_VOLUME=glucopilot_data
# Verified pre-migration backups default to /data/backups. Mount and set a
# separate path for off-volume protection on production deployments.
# MIGRATION_BACKUP_DIR=/data/backups
